# =============================================
# BOOKSTORE API - ENVIRONMENT CONFIGURATION
# =============================================
# Copy this file to .env and fill in actual values
# Never commit .env file with real secrets to git

# =============================================
# APPLICATION
# =============================================
NODE_ENV=production
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# =============================================
# DATABASE (MongoDB)
# =============================================
MONGODB_URI=mongodb://admin:password123@mongodb:27017/bookstore?authSource=admin

# =============================================
# CACHE (Redis)
# =============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379

# =============================================
# JWT & AUTHENTICATION
# =============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# =============================================
# EMAIL CONFIGURATION (SMTP)
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bookstore.com

# =============================================
# STRIPE PAYMENT GATEWAY
# =============================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# =============================================
# PAYPAL (Optional)
# =============================================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# =============================================
# AWS S3 (Optional)
# =============================================
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=bookstore-pdfs

# =============================================
# GOOGLE OAUTH (Optional)
# =============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# =============================================
# MESSAGE QUEUE (RabbitMQ) - Optional
# =============================================
AMQP_URL=amqp://guest:guest@localhost:5672

# =============================================
# ADMIN SETUP
# =============================================
ADMIN_EMAIL=admin@bookstore.com
ADMIN_PASSWORD=change-this-secure-password

# =============================================
# VERCEL/SERVERLESS (Optional)
# =============================================
VERCEL=false


# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Admin Credentials (for seeding)
ADMIN_EMAIL=admin@bookstore.com
ADMIN_PASSWORD=Admin@123

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
